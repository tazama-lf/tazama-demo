{
  "name": "tazama-demo",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env FORCE_COLOR=1 nodemon server.js",
    "build": "next build",
    "start": "node server.js",
    "clean": "npx rimraf .next node_modules coverage package-lock.json",
    "lint": "next lint",
    "lint:eslint": "next lint",
    "lint:eslint-unused": "next lint --report-unused-disable-directives",
    "lint:eslint-no-inline": "next lint --no-inline-config",
    "lint:fix": "next lint --fix",
    "lint:prettier": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "fix": "npm run fix:prettier && npm run fix:eslint",
    "fix:eslint": "next lint --fix",
    "fix:prettier": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "analyze": "cross-env ANALYZE=true npm run build",
    "prepare": "husky",
    "test": "cross-env SKIP_ENV_VALIDATION=1 FORCE_COLOR=1 jest --passWithNoTests",
    "e2e:headless": "playwright test",
    "e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "preinstall": "npx npm-only-allow@1.2.6 --PM npm",
    "coupling-graph": "npx madge --extensions js,jsx,ts,tsx,css,md,mdx ./ --exclude '.next|tailwind.config.js|reset.d.ts|prettier.config.js|postcss.config.js|playwright.config.ts|next.config.js|next-env.d.ts|instrumentation.ts|e2e/|README.md|.storybook/|eslint.config.mjs' --image graph.svg"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@hello-pangea/dnd": "18.0.1",
    "@tazama-lf/auth-lib": "4.0.0-rc.5",
    "next-auth": "5.0.0-beta.31",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "12.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.5",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^13.0.0",
    "@t3-oss/env-nextjs": "^0.10.1",
    "@tazama-lf/frms-coe-lib": "8.1.0-rc.0",
    "axios": "^1.7.3",
    "class-variance-authority": "^0.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nats": "^2.28.2",
    "next": "15.5.18",
    "nodemon": "^3.1.4",
    "radix-ui": "^1.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.77.8",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/plugin-syntax-flow": "^7.23.3",
    "@babel/plugin-transform-optional-chaining": "^7.23.4",
    "@babel/plugin-transform-react-jsx": "^7.23.4",
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.0.0",
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.12.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "all-contributors-cli": "^6.26.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "eslint": "^9.36.0",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "fetch-mock": "^9.11.0",
    "gzip-size": "6.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.1.2",
    "minimatch": "^9.0.9",
    "mkdirp": "^3.0.1",
    "npm-only-allow": "^1.2.6",
    "postcss": "^8.4.31",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "react-datepicker": "^7.3.0",
    "semantic-release": "^22.0.8",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.1",
    "tsc": "^2.0.4",
    "typescript": "5.4.5",
    "webpack": "5.94.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.5.2",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
